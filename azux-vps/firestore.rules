rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read/write their data
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // Global rules for any document
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }

    // Specific collection rules for Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && 
                     (request.resource.data.tenantId == request.auth.uid || isAdmin());
      
      // Subcollections
      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // Rules for Bills of Lading (Documents)
    match /documents/{bolId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Rules for EDI transactions
    match /edi/{ediId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rules for Inventory
    match /inventory/{inventoryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      
      match /movements/{movementId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // Rules for Master Data
    match /masters/{masterId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Rules for Shipments
    match /shipments/{shipmentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      
      match /tracking/{trackingId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // Rules for Users (profiles)
    match /users/{userId} {
      allow read: if isAuthenticated() && 
                     (request.auth.uid == userId || isAdmin());
      allow write: if request.auth.uid == userId;
    }
  }
}
