# ─── App ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ─── Database (used by both app and docker-compose) ──────────────────
POSTGRES_DB=azux_wms
POSTGRES_USER=azux_app
POSTGRES_PASSWORD=change_me_to_a_strong_password

# App connection string — when using docker-compose, host = "db"
DATABASE_URL=postgresql://azux_app:change_me_to_a_strong_password@db:5432/azux_wms

# ─── Auth / sessions ─────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
SESSION_SECRET=replace_with_random_64_hex_chars

# ─── Public (sent to the browser; must be prefixed with VITE_) ───────
# VITE_APP_NAME=AZUX 3PL WMS